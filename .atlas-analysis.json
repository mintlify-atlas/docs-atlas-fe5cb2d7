  "publicApiSurface": [
    "POST /v2/account - Create account",
    "GET /v2/account/{account_id}/seeds - Get account seeds",
    "POST /v2/account/{account_id}/sync - Sync account state",
    "GET /v2/account/{account_id}/orders - List orders",
    "POST /v2/account/{account_id}/orders - Create order",
    "GET /v2/account/{account_id}/orders/{order_id} - Get order",
    "POST /v2/account/{account_id}/orders/{order_id}/update - Update order",
    "POST /v2/account/{account_id}/orders/{order_id}/cancel - Cancel order",
    "GET /v2/account/{account_id}/balances - Get balances",
    "GET /v2/account/{account_id}/balances/{mint} - Get balance by mint",
    "POST /v2/account/{account_id}/balances/{mint}/deposit - Deposit funds",
    "POST /v2/account/{account_id}/balances/{mint}/withdraw - Withdraw funds",
    "GET /v2/account/{account_id}/tasks - List tasks",
    "GET /v2/account/{account_id}/tasks/{task_id} - Get task status",
    "POST /v2/external-matches - Submit external match",
    "GET /v2/markets - Get available markets",
    "GET /v2/markets/depth - Get market depth",
    "GET /v2/metadata - Get relayer metadata",
    "GET /v2/network/topology - Get network topology",
    "WebSocket /v2/account/{account_id}/ws - Real-time updates"
  ]
